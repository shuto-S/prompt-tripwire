{
  "name": "prompt-tripwire",
  "version": "0.1.8",
  "private": true,
  "license": "Apache-2.0",
  "description": "Local-first preflight and execution gate for Codex",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11.0.0"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "build": "tsc -b --pretty false && npm run build:web --workspace @prompt-tripwire/ui",
    "clean": "node scripts/clean.mjs",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "lint": "eslint .",
    "format": "prettier --write .agents .github apps packages plugins tests scripts package.json tsconfig.json tsconfig.base.json tsconfig.typecheck.json eslint.config.mjs .prettierrc.json",
    "format:check": "prettier --check .agents .github apps packages plugins tests scripts package.json tsconfig.json tsconfig.base.json tsconfig.typecheck.json eslint.config.mjs .prettierrc.json",
    "test": "node scripts/run-tests.mjs unit integration e2e",
    "test:unit": "node scripts/run-tests.mjs unit",
    "test:integration": "node scripts/run-tests.mjs integration",
    "test:e2e": "node scripts/run-tests.mjs e2e",
    "check": "node scripts/run-checks.mjs",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:versions": "node scripts/check-versions.mjs",
    "check:schema": "node scripts/spikes/codex-app-server.mjs schema",
    "check:licenses": "node scripts/check-licenses.mjs",
    "check:security": "node scripts/check-security.mjs",
    "check:plugin": "node scripts/check-plugin.mjs",
    "check:traceability": "node scripts/check-traceability.mjs",
    "check:submission": "node scripts/check-submission-content.mjs",
    "check:diff": "node scripts/check-diff.mjs",
    "eval:comparator": "npm run build && node scripts/eval-comparator.mjs",
    "smoke:real-probes": "npm run build && node scripts/smoke-real-probes.mjs",
    "package:macos-arm64": "npm run build && node scripts/package-macos-arm64.mjs",
    "check:release-reproducibility": "node scripts/check-release-reproducibility.mjs",
    "verify:release": "node scripts/verify-release-artifact.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.13.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  }
}
